# Copy this file to `.env` and fill in your keys.
# NEVER commit .env to git.

# ── LLM (Groq) ────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# ── Vector DB (Qdrant Cloud) ──────────────────────────────────
QDRANT_URL=https://your-cluster.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=eyJ_your_key_here
QDRANT_COLLECTION=disha_knowledge

# ── Embeddings + Reranker (HuggingFace Inference) ─────────────
HF_API_KEY=hf_your_key_here
HF_EMBEDDING_MODEL=BAAI/bge-m3
HF_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── OCR (OCR.space) ───────────────────────────────────────────
OCR_SPACE_API_KEY=K_your_key_here
OCR_SPACE_ENDPOINT=https://api.ocr.space/parse/image

# ── Maps (Google Maps) ────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza_your_key_here

# ── Google Document AI (deferred, for handwriting phase) ──────
# GOOGLE_DOC_AI_CREDENTIALS_JSON=/absolute/path/to/service-account.json

# ── Admin (protects /rag/* routes) ────────────────────────────
# Generate a strong random string — e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`
ADMIN_KEY=change_me_to_a_strong_random_string

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
LOG_LEVEL=INFO

# ── Data paths ────────────────────────────────────────────────
DATA_DIR=./app/data
STORAGE_DIR=./app/data/storage
UPLOAD_DIR=./app/data/storage/uploads
SQLITE_PATH=./app/data/storage/disha.db

# ── RAG thresholds (tunable) ──────────────────────────────────
RAG_MATCH_THRESHOLD=0.78
RAG_CONTEXT_THRESHOLD=0.62
AUTO_ENRICH_MIN_ANSWER_LEN=50

# ── File limits ───────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
