# Copy to `.env.local` for local overrides, or set in Vercel dashboard for prod.
# Leave VITE_API_URL UNSET in local dev — the Vite proxy in vite.config.ts
# forwards /api/* to http://127.0.0.1:8800 automatically.
#
# In production (Vercel): set this to your Render backend URL, e.g.:
#   VITE_API_URL=https://disha-backend.onrender.com
VITE_API_URL=
