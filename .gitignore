# ── Secrets — NEVER commit ─────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
service-account*.json
**/secrets/

# ── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Node / Vite ────────────────────────────────────────────
node_modules/
dist/
.vite/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Backend data/uploads (ephemeral, recreated at runtime) ─
backend/app/data/storage/*.db
backend/app/data/storage/uploads/
**/*.sqlite
**/*.sqlite3

# ── IDE / OS ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ── Local-only tooling ─────────────────────────────────────
.claude/
.agents/
